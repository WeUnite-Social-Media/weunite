{
  "name": "weunite-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev --parallel --filter=@weunite/web --filter=@weunite/api",
    "dev:web": "turbo run dev --filter=@weunite/web",
    "dev:api": "turbo run dev --filter=@weunite/api",
    "dev:mobile": "turbo run dev --filter=@weunite/mobile",
    "dev:infra": "docker compose -f infra/docker/compose.dev.yml up -d",
    "dev:infra:local": "node scripts/dev-infra-local.cjs",
    "dev:api:docker": "docker compose -f infra/docker/compose.api.yml up --build",
    "dev:api:docker:down": "docker compose -f infra/docker/compose.api.yml down",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "format": "turbo run format",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "turbo": "^2.5.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,yml,yaml}": "pnpm exec prettier --write"
  }
}
