# Base64 do PEM RSA completo, incluindo as linhas BEGIN/END.
JWT_PUBLIC_KEY=base64_do_pem_publico_rsa
JWT_PRIVATE_KEY=base64_do_pem_privado_rsa

DB_HOST=localhost
DB_PORT=5432
DB_NAME=weunite
DB_USERNAME=postgres
DB_PASSWORD=sua_password

# Valores precisam existir para a API subir. Podem ser credenciais locais/fictícias
# enquanto os fluxos de email não estiverem sendo exercitados.
MAIL_USERNAME=seu_email
MAIL_PASSWORD=sua_senha
MAIL_PORT=587

# Placeholder válido de formato; troque pelos dados reais ao testar upload de imagens.
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
